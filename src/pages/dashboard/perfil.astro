---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { AuthService } from '../../services/auth.service';
import { formatDate } from '../../lib/utils';

const { session } = Astro.locals;
const profile = await AuthService.getProfile(session!.user.id);
---

<DashboardLayout title="Meu Perfil" session={session!}>
  <h1 class="text-2xl font-display font-bold mb-6">Meu Perfil</h1>

  <div class="card max-w-lg space-y-4">
    <div>
      <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">E-mail</p>
      <p class="text-white">{session!.user.email}</p>
    </div>

    <div>
      <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Nome</p>
      <p class="text-white">{profile?.full_name ?? '—'}</p>
    </div>

    <div>
      <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Membro desde</p>
      <p class="text-white">
        {profile ? formatDate(profile.created_at) : '—'}
      </p>
    </div>

    <div class="pt-4 border-t border-zinc-800">
      <a href="/api/auth/reset-password" class="btn-secondary text-sm px-4 py-2">
        Alterar senha
      </a>
    </div>
  </div>
</DashboardLayout>
