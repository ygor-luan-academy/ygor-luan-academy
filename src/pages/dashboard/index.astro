---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import ProgressTracker from '../../islands/ProgressTracker';
import { LessonsService } from '../../services/lessons.service';
import { ProgressService } from '../../services/progress.service';

const { session } = Astro.locals;
const [lessons, completedCount] = await Promise.all([
  LessonsService.getAll(),
  ProgressService.getCompletedCount(session!.user.id),
]);
---

<DashboardLayout title="Meu Progresso" session={session!}>
  <h1 class="text-2xl font-display font-bold mb-6">
    Olá! 👋
  </h1>

  <div class="card mb-6">
    <h2 class="font-semibold mb-4">Seu progresso</h2>
    <ProgressTracker
      totalLessons={lessons.length}
      completedLessons={completedCount}
      client:load
    />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <a href="/dashboard/aulas" class="card hover:border-zinc-600 transition-colors">
      <h3 class="font-semibold mb-1">Continuar assistindo</h3>
      <p class="text-sm text-zinc-400">{lessons.length} aulas disponíveis</p>
    </a>
    <a href="/dashboard/mentoria" class="card hover:border-zinc-600 transition-colors">
      <h3 class="font-semibold mb-1">Agendar mentoria</h3>
      <p class="text-sm text-zinc-400">Sessão 1:1 com Ygor Luan</p>
    </a>
  </div>
</DashboardLayout>
