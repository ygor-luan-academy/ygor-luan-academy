---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro';
import QuizPlayer from '../../../islands/QuizPlayer';
import { QuizService } from '../../../services/quiz.service';
import { LessonsService } from '../../../services/lessons.service';

const { user, hasAccess } = Astro.locals;
if (!hasAccess) return Astro.redirect('/sem-acesso');

const moduleNumber = Number(Astro.params.module);
if (isNaN(moduleNumber) || moduleNumber < 1) return Astro.redirect('/dashboard/aulas');

const [questions, bestAttempt, modules] = await Promise.all([
  QuizService.getPublicQuestionsByModule(moduleNumber).catch(() => []),
  QuizService.getBestAttempt(user!.id, moduleNumber).catch(() => null),
  LessonsService.getAllModules().catch(() => []),
]);

const moduleTitle = modules.find((m) => m.order_number === moduleNumber)?.title ?? `Módulo ${moduleNumber}`;
---

<DashboardLayout title={`Quiz — ${moduleTitle}`} user={user!}>
  <a href="/dashboard/aulas" class="back-link font-sans text-sm">← Voltar para aulas</a>
  <p class="section-eyebrow mt-6">Quiz</p>
  <h1 class="font-display font-light text-4xl mt-1 mb-6" style="color: var(--cream);">{moduleTitle}</h1>
  <div class="page-divider"></div>
  <QuizPlayer moduleNumber={moduleNumber} questions={questions} initialBestAttempt={bestAttempt} client:load />
</DashboardLayout>

<style>
  .back-link { color: var(--fade); transition: color 0.2s; }
  .back-link:hover { color: var(--parchment); }
</style>
