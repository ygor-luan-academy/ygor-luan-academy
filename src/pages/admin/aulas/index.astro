---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro';
import { LessonsService } from '../../../services/lessons.service';

const { session } = Astro.locals;
const lessons = await LessonsService.getAllAdmin();
---

<DashboardLayout title="Aulas" session={session!}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-display font-bold">Aulas</h1>
    <a href="/admin/aulas/nova" class="btn-primary text-sm px-4 py-2">+ Nova Aula</a>
  </div>

  <div class="space-y-2">
    {lessons.map((lesson) => (
      <div class="card flex items-center gap-4">
        <div class:list={[
          'w-2 h-2 rounded-full flex-shrink-0',
          lesson.is_published ? 'bg-green-500' : 'bg-zinc-600',
        ]} />
        <div class="flex-1 min-w-0">
          <p class="font-medium truncate">{lesson.title}</p>
          <p class="text-xs text-zinc-500">
            Módulo {lesson.module_number} · Aula {lesson.order_number}
            {!lesson.is_published && ' · Rascunho'}
          </p>
        </div>
        <a href={`/admin/aulas/${lesson.id}/editar`} class="text-sm text-brand-400 hover:underline flex-shrink-0">
          Editar
        </a>
      </div>
    ))}

    {lessons.length === 0 && (
      <div class="card text-center text-zinc-400 py-12">
        Nenhuma aula ainda.
        <a href="/admin/aulas/nova" class="text-brand-400 hover:underline ml-1">Criar primeira aula</a>
      </div>
    )}
  </div>
</DashboardLayout>
