---
import DashboardLayout from '../../../../components/layout/DashboardLayout.astro';
import AdminLessonForm from '../../../../islands/AdminLessonForm';
import { LessonsService } from '../../../../services/lessons.service';

const { session } = Astro.locals;
const { id } = Astro.params;

if (!id) return Astro.redirect('/admin/aulas');

let lesson;
try {
  lesson = await LessonsService.getById(id);
} catch {
  return Astro.redirect('/admin/aulas');
}
---

<DashboardLayout title="Editar Aula" session={session!}>
  <div class="max-w-2xl">
    <div class="mb-6">
      <a href="/admin/aulas" class="text-sm text-zinc-400 hover:text-white transition-colors">
        ← Voltar
      </a>
    </div>
    <h1 class="text-2xl font-display font-bold mb-6">Editar: {lesson.title}</h1>
    <div class="card">
      <AdminLessonForm mode="edit" lesson={lesson} client:load />
    </div>
  </div>
</DashboardLayout>
