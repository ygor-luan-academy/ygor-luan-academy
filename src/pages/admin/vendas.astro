---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { OrdersService } from '../../services/orders.service';
import { formatCurrency, formatDate } from '../../lib/utils';

const { session } = Astro.locals;
const orders = await OrdersService.getAllAdmin();
const totalRevenue = orders
  .filter((o) => o.status === 'approved')
  .reduce((sum, o) => sum + o.amount, 0);

const statusClass: Record<string, string> = {
  approved: 'bg-green-500/20 text-green-400',
  pending: 'bg-yellow-500/20 text-yellow-400',
  refunded: 'bg-blue-500/20 text-blue-400',
  rejected: 'bg-red-500/20 text-red-400',
};
---

<DashboardLayout title="Vendas" session={session!}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-display font-bold">Vendas</h1>
    <div class="card px-4 py-2 text-right">
      <p class="text-xs text-zinc-400">Total aprovado</p>
      <p class="text-xl font-bold text-brand-400">{formatCurrency(totalRevenue)}</p>
    </div>
  </div>

  <div class="card overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-zinc-800 text-left">
          <th class="pb-3 pr-4 font-medium text-zinc-400">Payment ID</th>
          <th class="pb-3 pr-4 font-medium text-zinc-400">Valor</th>
          <th class="pb-3 pr-4 font-medium text-zinc-400">Status</th>
          <th class="pb-3 font-medium text-zinc-400">Data</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-800">
        {orders.map((order) => (
          <tr>
            <td class="py-3 pr-4 font-mono text-xs text-zinc-400">{order.payment_id}</td>
            <td class="py-3 pr-4 font-medium text-white">{formatCurrency(order.amount)}</td>
            <td class="py-3 pr-4">
              <span class:list={['px-2 py-0.5 rounded-full text-xs font-medium', statusClass[order.status] ?? '']}>
                {order.status}
              </span>
            </td>
            <td class="py-3 text-zinc-400">{formatDate(order.created_at)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</DashboardLayout>
