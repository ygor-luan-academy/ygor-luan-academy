---
import type { Session } from '@supabase/supabase-js';

interface Props {
  title: string;
  session: Session;
}
const { title, session } = Astro.props;
const pathname = Astro.url.pathname;
const isAdmin = session.user.user_metadata?.role === 'admin';

const navItems = [
  { href: '/dashboard', label: 'Início' },
  { href: '/dashboard/aulas', label: 'Aulas' },
  { href: '/dashboard/mentoria', label: 'Mentoria 1:1' },
  { href: '/dashboard/perfil', label: 'Perfil' },
];

const adminItems = [
  { href: '/admin', label: 'Admin' },
  { href: '/admin/aulas', label: 'Gerenciar Aulas' },
  { href: '/admin/alunos', label: 'Alunos' },
  { href: '/admin/vendas', label: 'Vendas' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} – Ygor Luan Academy</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="bg-zinc-950 text-white">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-zinc-900 border-r border-zinc-800 flex flex-col hidden md:flex">
        <div class="p-6 border-b border-zinc-800">
          <a href="/" class="text-lg font-display font-bold">
            Ygor Luan <span class="text-brand-400">Academy</span>
          </a>
        </div>

        <nav class="flex-1 p-4 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'flex items-center px-3 py-2 rounded-lg text-sm transition-colors',
                pathname === item.href
                  ? 'bg-brand-500/10 text-brand-400 font-medium'
                  : 'text-zinc-400 hover:text-white hover:bg-zinc-800',
              ]}
            >
              {item.label}
            </a>
          ))}

          {isAdmin && (
            <>
              <div class="pt-4 pb-2 px-3 text-xs font-medium text-zinc-600 uppercase tracking-wider">
                Admin
              </div>
              {adminItems.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'flex items-center px-3 py-2 rounded-lg text-sm transition-colors',
                    pathname.startsWith(item.href)
                      ? 'bg-brand-500/10 text-brand-400 font-medium'
                      : 'text-zinc-400 hover:text-white hover:bg-zinc-800',
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </>
          )}
        </nav>

        <div class="p-4 border-t border-zinc-800">
          <p class="text-xs text-zinc-500 truncate mb-2">{session.user.email}</p>
          <a href="/api/auth/signout" class="text-sm text-zinc-400 hover:text-white transition-colors">
            Sair
          </a>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-6 md:p-8 overflow-y-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
